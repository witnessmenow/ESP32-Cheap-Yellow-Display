# Backend config for vm-switcher-api. Copy to .env (which should be gitignored).

# Shared secret the panel sends in the X-API-Key header.
# Generate a random one, e.g.:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=CHANGE_ME_RANDOM_TOKEN

# SSH target for your Proxmox host. Passwordless key auth must already work:
#   ssh root@YOUR_PROXMOX_HOST "qm list"
PVE_HOST=root@YOUR_PROXMOX_HOST

# Optional: comma-separated VMIDs to hide from the panel (e.g. the box running this API).
EXCLUDE_VMIDS=

# Optional: comma-separated VMIDs that share a single passthrough iGPU
# (only one of them may run at a time; enables the /switch endpoint).
IGPU_GROUP=
